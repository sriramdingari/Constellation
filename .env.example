# Required only when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
# Optional: custom base URL for OpenAI-compatible APIs (e.g. LiteLLM)
# OPENAI_BASE_URL=http://localhost:4000

# Neo4j (defaults work with docker-compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=constellation

# Redis (defaults work with docker-compose)
REDIS_URL=redis://localhost:6379

# Embedding config
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
OLLAMA_BASE_URL=http://localhost:11434

# Indexing defaults
EMBEDDING_BATCH_SIZE=8
ENTITY_BATCH_SIZE=100
